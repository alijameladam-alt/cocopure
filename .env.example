# ── AssemblyAI ──────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LinkedIn OAuth ──────────────────────────────────────────
# Register your app at: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/linkedin/callback

# ── App Security ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_hex_string

# ── URLs ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── Upload limits ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=2000
UPLOAD_TEMP_DIR=/tmp/uploads
